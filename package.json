{
  "name": "slidev-theme-ds",
  "version": "1.0.0",
  "type": "module",
  "description": "Slidev theme by Damian Ślimak for IT training and conference presentations",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "engines": {
    "node": ">=18.0.0",
    "slidev": ">=0.49.0"
  },
  "dependencies": {
    "@slidev/types": "^52.11.5",
    "slidev-addon-announcement": "^0.1.5",
    "slidev-addon-sync": "^0.1.0",
    "slidev-component-poll": "^3.0.0"
  },
  "devDependencies": {
    "@iconify-json/fa7-brands": "^1.2.1",
    "@iconify-json/fa7-regular": "^1.2.2",
    "@iconify-json/fa7-solid": "^1.2.3",
    "@slidev/cli": "^52.11.5",
    "@unocss/preset-icons": "^66.6.0",
    "playwright-chromium": "^1.58.1",
    "unocss": "^66.6.0"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "dark",
    "defaults": {
      "fonts": {
        "mono": "Fira Code",
        "serif": "Roboto Serif",
        "sans": "Lexend,Roboto"
      },
      "transition": "fade",
      "aspectRatio": "16/9"
    }
  },
  "author": "Damian Ślimak <oidnus@gmail.com>",
  "homepage": "https://github.com/damianslimak/slidev-theme-ds",
  "repository": {
    "type": "git",
    "url": "https://github.com/damianslimak/slidev-theme-ds.git"
  },
  "bugs": "https://github.com/damianslimak/slidev-theme-ds/issues",
  "scripts": {
    "build": "slidev build example.md",
    "dev": "slidev example.md --open",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  }
}